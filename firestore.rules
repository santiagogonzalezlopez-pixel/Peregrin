rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPremiumOwner(userId) {
      return isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId)).data.isPremium == true;
    }

    function mutableUserFields() {
      return ['visits', 'lang', 'displayName', 'onboardingSeen'];
    }

    function premiumUserFields() {
      return [
        'isPremium',
        'unlockedRegions',
        'premiumSource',
        'premiumCode',
        'premiumUnlockedAt'
      ];
    }

    function isEmergencyPremiumCode(code) {
      return code == 'PEREGRIN-388066-6291'
        || code == 'PEREGRIN-PREMIUM-2026';
    }

    function validUserFields(data) {
      return (!('visits' in data) || data.visits is map)
        && (!('lang' in data) || (data.lang is string && data.lang.size() == 2))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 80))
        && (!('onboardingSeen' in data) || data.onboardingSeen is bool);
    }

    function validPremiumUnlock(data) {
      return data.isPremium == true
        && data.unlockedRegions is list
        && data.unlockedRegions.size() == 1
        && data.unlockedRegions[0] == 'all'
        && data.premiumSource == 'code'
        && data.premiumCode is string
        && data.premiumCode.size() >= 6
        && data.premiumCode.size() <= 64
        && data.premiumUnlockedAt is string
        && (
          isEmergencyPremiumCode(data.premiumCode)
          || (
            exists(/databases/$(database)/documents/premiumCodes/$(data.premiumCode))
            && get(/databases/$(database)/documents/premiumCodes/$(data.premiumCode)).data.active == true
          )
        );
    }

    function changedOnlyMutableOrPremium() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(mutableUserFields().concat(premiumUserFields()));
    }

    function validJournalEntry(sanctuaryId, data) {
      return data.keys().hasOnly(['sanctuaryId', 'text', 'updatedAtMs', 'updatedAtIso'])
        && data.sanctuaryId is string
        && data.sanctuaryId == sanctuaryId
        && data.text is string
        && data.text.size() <= 1000
        && data.updatedAtMs is int
        && data.updatedAtIso is string;
    }

    function mutableCommentFields() {
      return ['text', 'edited', 'updatedAtMs', 'updatedAtIso'];
    }

    function validCommentEntry(sanctuaryId, data) {
      return data.keys().hasOnly([
          'sanctuaryId',
          'text',
          'authorName',
          'authorUid',
          'createdAtMs',
          'createdAtIso',
          'edited',
          'updatedAtMs',
          'updatedAtIso'
        ])
        && data.authorUid is string
        && data.authorName is string
        && data.authorName.size() > 0
        && data.authorName.size() <= 80
        && data.text is string
        && data.text.size() >= 3
        && data.text.size() <= 280
        && data.createdAtMs is int
        && data.createdAtIso is string
        && data.sanctuaryId is string
        && data.sanctuaryId == sanctuaryId
        && (!('edited' in data) || data.edited is bool)
        && (!('updatedAtMs' in data) || data.updatedAtMs is int)
        && (!('updatedAtIso' in data) || data.updatedAtIso is string);
    }

    function validAnalyticsEvent(data) {
      return data.keys().hasAll([
          'event',
          'uid',
          'sessionId',
          'sequence',
          'createdAtMs',
          'createdAtIso',
          'lang',
          'screen',
          'platform',
          'isPremium',
          'visitCount'
        ])
        && data.keys().hasOnly([
          'event',
          'uid',
          'sessionId',
          'sequence',
          'createdAtMs',
          'createdAtIso',
          'lang',
          'screen',
          'platform',
          'isPremium',
          'visitCount',
          'countryId',
          'sanctuaryId',
          'routeId',
          'achievementId',
          'region',
          'provider',
          'outcome',
          'source',
          'itemId',
          'errorCode',
          'count',
          'percent'
        ])
        && data.event is string
        && data.event.size() > 0
        && data.event.size() <= 64
        && data.uid is string
        && data.uid == request.auth.uid
        && data.sessionId is string
        && data.sessionId.size() > 8
        && data.sessionId.size() <= 80
        && data.sequence is int
        && data.createdAtMs is int
        && data.createdAtIso is string
        && data.lang is string
        && data.lang.size() == 2
        && data.screen is string
        && data.screen.size() <= 40
        && data.platform is string
        && data.platform.size() <= 20
        && data.isPremium is bool
        && data.visitCount is int
        && (!('countryId' in data) || (data.countryId is string && data.countryId.size() <= 80))
        && (!('sanctuaryId' in data) || (data.sanctuaryId is string && data.sanctuaryId.size() <= 80))
        && (!('routeId' in data) || (data.routeId is string && data.routeId.size() <= 80))
        && (!('achievementId' in data) || (data.achievementId is string && data.achievementId.size() <= 80))
        && (!('region' in data) || (data.region is string && data.region.size() <= 80))
        && (!('provider' in data) || (data.provider is string && data.provider.size() <= 80))
        && (!('outcome' in data) || (data.outcome is string && data.outcome.size() <= 80))
        && (!('source' in data) || (data.source is string && data.source.size() <= 80))
        && (!('itemId' in data) || (data.itemId is string && data.itemId.size() <= 80))
        && (!('errorCode' in data) || (data.errorCode is string && data.errorCode.size() <= 80))
        && (!('count' in data) || data.count is int)
        && (!('percent' in data) || data.percent is int);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(mutableUserFields())
        && validUserFields(request.resource.data);
      allow update: if isOwner(userId)
        && changedOnlyMutableOrPremium()
        && validUserFields(request.resource.data)
        && (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(mutableUserFields())
          || validPremiumUnlock(request.resource.data)
        );
      allow delete: if false;

      match /journal/{sanctuaryId} {
        allow read: if isPremiumOwner(userId);
        allow create, update: if isPremiumOwner(userId)
          && validJournalEntry(sanctuaryId, request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /sanctuaries/{sanctuaryId}/comments/{commentId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && validCommentEntry(sanctuaryId, request.resource.data);

      allow update: if signedIn()
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.sanctuaryId == sanctuaryId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(mutableCommentFields())
        && validCommentEntry(sanctuaryId, request.resource.data);

      allow delete: if signedIn()
        && resource.data.authorUid == request.auth.uid;

      match /reports/{reporterUid} {
        allow read: if false;
        allow create, update: if signedIn()
          && request.auth.uid == reporterUid
          && request.resource.data.reporterUid == request.auth.uid
          && request.resource.data.sanctuaryId is string
          && request.resource.data.sanctuaryId == sanctuaryId
          && request.resource.data.commentId is string
          && request.resource.data.commentId == commentId
          && request.resource.data.createdAtMs is int
          && request.resource.data.createdAtIso is string;
        allow delete: if false;
      }
    }

    match /analyticsEvents/{eventId} {
      allow create: if signedIn() && validAnalyticsEvent(request.resource.data);
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
